BOT_TOKEN=
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/post_writer_bot
REDIS_URL=redis://redis:6379/0
AUTO_INIT_DB=true
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=60
TELEGRAM_TIMEOUT_SECONDS=30
TELEGRAM_CLIENT_API_ID=
TELEGRAM_CLIENT_API_HASH=
TELEGRAM_CLIENT_DATA_DIR=/app/telegram_client_data
TELEGRAM_CLIENT_SESSION_NAME=post_writer_client
TELEGRAM_CLIENT_ADMIN_TOKEN=
TELEGRAM_CLIENT_TIMEOUT_SECONDS=10
ANALYZE_JOB_TIMEOUT_SECONDS=360
GENERATE_IDEAS_JOB_TIMEOUT_SECONDS=240
GENERATE_POST_JOB_TIMEOUT_SECONDS=360
FOLLOWUP_FAST_MODE=true
MOCK_PAYMENTS=true
APP_ENV=local
